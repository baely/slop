# Copy to .env and fill in. All optional — blank = demo mode.

# TMDB — get a key at https://www.themoviedb.org/settings/api
# Use EITHER a v3 API key OR a v4 read access token (bearer).
TMDB_API_KEY=
TMDB_BEARER=

# Public hostname Traefik routes to (keep it internal — see security note below)
MARQUEE_HOST=marquee.home.baileys.app
# Traefik forward-auth middleware to gate it (e.g. authelia@docker). Strongly advised.
MARQUEE_AUTH=

# Radarr — Settings → General → Security → API Key
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Optional Radarr defaults (auto-detected from Radarr if left blank)
RADARR_QUALITY_PROFILE_ID=
RADARR_ROOT_FOLDER=

OWNER=bailey
