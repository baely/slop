# Address the server listens on.
ADDR=:8080

# Path to the SQLite database file (inside the container it lives on /data).
DB_PATH=/data/voyage.db

# App title shown in the UI.
TITLE=Voyage

# Default currency code prefilled in budget/hotel forms (e.g. AUD, USD, GBP, EUR).
# Symbols are derived for display ($ for AUD/USD, £ for GBP, € for EUR, ...).
CURRENCY=AUD

# Required in production: the planner (owner) access token. Anyone with it can
# create and edit trips. Travellers never need it — they use the share link.
ADMIN_TOKEN=change-me

# Absolute base URL used when generating share links. If empty, links are built
# from the incoming request host.
BASE_URL=https://voyage.baileys.app

# Set to 1 when behind a reverse proxy (Traefik) that sets X-Forwarded-Proto.
TRUST_PROXY=1
