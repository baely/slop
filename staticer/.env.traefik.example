# Traefik + Staticer Production Environment

# Domain Configuration
DOMAIN=lab.baileys.app

# Let's Encrypt
ACME_EMAIL=admin@baileys.app

# Traefik Dashboard Authentication
# Generate with: docker run --rm httpd:alpine htpasswd -nb admin yourpassword | sed -e s/\\$/\\$\\$/g
# Example result: admin:$$apr1$$abc123$$xyz
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# Traefik Logging
TRAEFIK_LOG_LEVEL=INFO

# Staticer Secrets (REQUIRED: Generate strong secrets!)
# Generate with: openssl rand -hex 32
UPLOAD_SECRET=changeme-generate-with-openssl-rand
ADMIN_SECRET=changeme-generate-with-openssl-rand

# Staticer Limits
MAX_UPLOAD_SIZE=104857600        # 100MB
MAX_EXTRACTED_SIZE=524288000     # 500MB
MAX_FILES_PER_SITE=1000
RATE_LIMIT_UPLOADS=10
