# Production Docker Environment Configuration
# Copy this file to .env and set your secrets

# Server Configuration
SERVER_HOST=lab.baileys.app
SERVER_PORT=8080

# Security (REQUIRED: Generate strong secrets!)
# Generate with: openssl rand -hex 32
UPLOAD_SECRET=your-upload-secret-here
ADMIN_SECRET=your-admin-secret-here

# Limits
MAX_UPLOAD_SIZE=104857600        # 100MB
MAX_EXTRACTED_SIZE=524288000     # 500MB
MAX_FILES_PER_SITE=1000
RATE_LIMIT_UPLOADS=10
