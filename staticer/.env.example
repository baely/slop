# Server Configuration
SERVER_PORT=8080
SERVER_HOST=lab.baileys.app
SITES_DIR=./sites
DATABASE_PATH=./data/staticer.db

# Secrets (CHANGE THESE!)
UPLOAD_SECRET=your-secret-here-change-this
ADMIN_SECRET=your-admin-secret-here-change-this

# Upload Limits
MAX_UPLOAD_SIZE=104857600        # 100MB in bytes
MAX_EXTRACTED_SIZE=524288000     # 500MB in bytes
MAX_FILES_PER_SITE=1000
RATE_LIMIT_UPLOADS=10            # per IP per hour

# TLS (for production)
TLS_ENABLED=false
TLS_CERT_CACHE=/var/cache/staticer
TLS_EMAIL=admin@baileys.app
