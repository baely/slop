# TMDB API read-access token used to enrich movies with posters/metadata.
# Without this, entries are stored but no metadata is populated.
TMDB_TOKEN=

# Branding shown in the viewer header.
TITLE=Viewing Schedule

# Optional human-readable date range badge (e.g. "Apr 10 — May 9, 2026").
DATE_RANGE=

# Host port to publish the service on.
PORT=8080

# Set to 1 when running behind a reverse proxy that sets X-Forwarded-For.
# When enabled, the admin IP allow-list (10.x.x.x, 192.168.x.x, loopback)
# is evaluated against the forwarded client IP.
TRUST_PROXY=0

# Letterboxd username whose diary should be synced into the local history.
# When set, /history shows a year-at-a-glance calendar of past viewings and
# the admin panel exposes Sync now / Force full sync / Download CSV controls.
# Leave empty to disable diary sync entirely.
LETTERBOXD_USER=

# How often to refresh the diary in the background. Use Go duration format
# (e.g. 30m, 1h, 6h, 24h). Set to 0 to disable periodic sync (manual only).
SYNC_INTERVAL=6h
